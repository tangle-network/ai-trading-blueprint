# Tangle protocol settings.
# Local dev keeps these at placeholder values until `./scripts/deploy-local.sh`
# writes real addresses. For Base Sepolia, source `./scripts/load-base-sepolia-env.sh`
# before starting operator-side processes.
BLUEPRINT_ID=0
SERVICE_ID=0
# Protocol deploy overrides these with real addresses.
TANGLE_CONTRACT=0x0000000000000000000000000000000000000001
RESTAKING_CONTRACT=0x0000000000000000000000000000000000000001
STATUS_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000001
