{
  "name": "ai-trading-blueprint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:evals": "tsc -p evals/tsconfig.json",
    "eval:agent-strategy": "npm run build:evals --silent && node dist/evals/bin/trading-agent-strategy-eval.js",
    "eval:autoresearch-loop": "npm run build:evals --silent && node dist/evals/bin/autoresearch-loop-eval.js",
    "eval:full": "npm run build:evals --silent && node dist/evals/bin/full-eval.js",
    "eval:chat-code-strategy": "npm run build:evals --silent && node dist/evals/bin/chat-code-strategy-e2e.js",
    "eval:chat-mcp-strategy": "npm run build:evals --silent && node dist/evals/bin/chat-mcp-strategy-e2e.js",
    "eval:chat-sandbox": "npm run build:evals --silent && node dist/evals/bin/chat-sandbox-e2e.js",
    "eval:local-product": "npm run build:evals --silent && node dist/evals/bin/local-product-e2e.js",
    "eval:product-browser": "npm run build:evals --silent && node dist/evals/bin/product-browser-eval.js",
    "eval:self-improvement-mcp": "npm run build:evals --silent && node dist/evals/bin/self-improvement-mcp-eval.js",
    "eval:strategy-templates": "npm run build:evals --silent && node dist/evals/bin/strategy-template-eval.js",
    "eval:trading-lifecycle": "npm run build:evals --silent && node dist/evals/bin/trading-lifecycle-eval.js",
    "eval:trading-personas": "npm run build:evals --silent && node dist/evals/bin/agent-eval-trading-personas.js",
    "eval:trading-persona-matrix": "npm run build:evals --silent && TRADING_PERSONA_MATRIX=1 node dist/evals/bin/agent-eval-trading-personas.js",
    "eval:trading-conversation-matrix": "npm run build:evals --silent && TRADING_CONVERSATION_MATRIX=1 node dist/evals/bin/agent-eval-trading-personas.js",
    "eval:trading-decision-loop": "npm run build:evals --silent && TRADING_DECISION_LOOP=1 node dist/evals/bin/agent-eval-trading-personas.js",
    "agent:user-lab": "npm run build:evals --silent && node dist/evals/bin/active-user-lab.js",
    "agent:fleet-audit": "npm run build:evals --silent && node dist/evals/bin/live-agent-fleet-audit.js",
    "release:local-artifacts": "scripts/release-local-artifacts.sh",
    "typecheck:evals": "tsc -p evals/tsconfig.json --noEmit",
    "eval:harness-self-improve": "npm run build:evals --silent && node dist/evals/bin/harness-self-improve-eval.js",
    "eval:per-bot-self-improve": "npm run build:evals --silent && node dist/evals/bin/per-bot-self-improve-eval.js",
    "eval:planted-improvement": "npm run build:evals --silent && node dist/evals/bin/planted-improvement-eval.js",
    "eval:breaker-recovery": "npm run build:evals --silent && node dist/evals/bin/breaker-recovery-eval.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tangle-network/agent-eval": "^0.91.0",
    "@tangle-network/agent-knowledge": "^1.7.0",
    "@tangle-network/agent-runtime": "^0.52.0"
  }
}
