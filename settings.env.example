# Local operator settings for Base Sepolia rollouts.
#
# This file is safe to track because all values below are placeholders.
# Copy to `settings.env` for local use and fill in real operator values.

SERVICE_ID=0
BLUEPRINT_ID=0
CHAIN_ID=84532

# Load current protocol addresses from `./scripts/load-base-sepolia-env.sh`
# or replace these placeholders with the latest manifest-derived values.
TANGLE_CONTRACT=0x0000000000000000000000000000000000000001
STAKING_CONTRACT=0x0000000000000000000000000000000000000001
RESTAKING_CONTRACT=0x0000000000000000000000000000000000000001
STATUS_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000001

# Public RPC defaults are fine for examples. Override locally if needed.
HTTP_RPC_URL=https://sepolia.base.org
WS_RPC_URL=wss://base-sepolia-rpc.publicnode.com

OPERATOR_API_PORT=9200
TRADING_API_PORT=9100

# Base Sepolia USDC for paper-trading examples.
ASSET_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

SIDECAR_IMAGE=ghcr.io/tangle-network/blueprint-sidecar:all-harness

# Optional: let the binary derive this from keystore/private key instead.
SESSION_AUTH_SECRET=

# Optional: operator-provided AI key for auto-activation flows.
ZAI_API_KEY=
OPENCODE_MODEL_PROVIDER=zai-coding-plan
OPENCODE_MODEL_NAME=glm-4.7
OPENCODE_MODEL_API_KEY=

# Optional: set this for billing/status flows that read the operator identity.
OPERATOR_ADDRESS=0x0000000000000000000000000000000000000000
