{
  "manifest_version": 3,
  "name": "Playwright Web3 Mock Wallet",
  "version": "0.1.0",
  "description": "Injects a local mock wallet for AI Trading Arena verification flows.",
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:1337/*",
        "http://localhost:1337/*",
        "http://127.0.0.1:1338/*",
        "http://localhost:1338/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-wallet.js"
      ],
      "matches": [
        "http://127.0.0.1:1337/*",
        "http://localhost:1337/*",
        "http://127.0.0.1:1338/*",
        "http://localhost:1338/*"
      ]
    }
  ]
}
