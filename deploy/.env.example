# === Required ===

# Operator wallet private key (hex, with 0x prefix).
# Used for signing on-chain transactions AND Hyperliquid L1 orders.
# CRITICAL: This key controls funds. Protect it.
PRIVATE_KEY=0x...

# Operator Ethereum address (checksummed)
OPERATOR_ADDRESS=0x...

# RPC endpoint for the chain where vaults are deployed
HTTP_RPC_URL=https://rpc.tangle.tools
WS_RPC_URL=wss://rpc.tangle.tools
# Or for Arbitrum (HL bridge): https://arb1.arbitrum.io/rpc

# Chain ID
CHAIN_ID=5845  # Tangle testnet

# === Tangle Protocol ===

BLUEPRINT_ID=0
SERVICE_ID=1
KEYSTORE_URI=/data/blueprint-state/keystore
TANGLE_CONTRACT=0x...
STAKING_CONTRACT=0x...
STATUS_REGISTRY_CONTRACT=0x...

# === AI Provider ===

# Set one of these:
# ZAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# TANGLE_ROUTER_API_KEY=...

# Optional for Tangle Router / OpenRouter-compatible inference.
# Defaults to https://router.tangle.tools/v1 in the deploy flow.
# TANGLE_ROUTER_BASE_URL=https://router.tangle.tools/v1

# === Trading Config ===

# Max bots this operator will run (default: 10)
OPERATOR_MAX_CAPACITY=10

# Market data provider
MARKET_DATA_BASE_URL=https://api.coingecko.com/api/v3

# Validator config
VALIDATION_DEADLINE_SECS=3600
VALIDATOR_MIN_SCORE=50

# Comma-separated validator endpoints (or use on-chain discovery)
# VALIDATOR_ENDPOINTS=http://validator1:9090,http://validator2:9090

# === Hyperliquid ===

# Set to "1" for HL testnet, omit or "0" for mainnet
# HYPERLIQUID_TESTNET=1

# === Optional ===

# Session auth (auto-derived from keystore if not set)
# SESSION_AUTH_SECRET=...

# Sidecar Docker image for bot sandboxes
# SIDECAR_IMAGE=tangle-sidecar:local

# Custom ports
# OPERATOR_API_PORT=9200
# TRADING_API_PORT=9100

# Logging
RUST_LOG=info,trading_blueprint_lib=debug
