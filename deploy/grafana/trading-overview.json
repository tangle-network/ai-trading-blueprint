{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping trading-http-api /metrics/prometheus.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["trading", "envelope", "operator"],
  "templating": {
    "list": [
      {
        "name": "bot_id",
        "label": "Bot ID",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(trading_envelope_max_total, bot_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "protocol",
        "label": "Protocol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(trading_envelope_max_total{bot_id=~\"$bot_id\"}, protocol)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "title": "Trading Overview",
  "uid": "trading-overview",
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Envelope consumption % per bot",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "100 * trading_envelope_consumed_amount{bot_id=~\"$bot_id\", protocol=~\"$protocol\"} / clamp_min(trading_envelope_max_total{bot_id=~\"$bot_id\", protocol=~\"$protocol\"}, 1)",
          "legendFormat": "{{bot_id}} / {{protocol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Time to envelope expiry",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 21600 },
              { "color": "yellow", "value": 86400 },
              { "color": "green", "value": 172800 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "trading_envelope_expires_at_seconds{bot_id=~\"$bot_id\", protocol=~\"$protocol\"} - time()",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Trade success rate per protocol",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (protocol) (rate(trading_executions_total{status=\"success\", bot_id=~\"$bot_id\"}[5m])) / clamp_min(sum by (protocol) (rate(trading_executions_total{bot_id=~\"$bot_id\"}[5m])), 1e-10)",
          "legendFormat": "{{protocol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Trade latency p50/p95/p99 per protocol",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, protocol) (rate(trading_execution_latency_seconds_bucket{bot_id=~\"$bot_id\"}[5m])))",
          "legendFormat": "p50 — {{protocol}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, protocol) (rate(trading_execution_latency_seconds_bucket{bot_id=~\"$bot_id\"}[5m])))",
          "legendFormat": "p95 — {{protocol}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, protocol) (rate(trading_execution_latency_seconds_bucket{bot_id=~\"$bot_id\"}[5m])))",
          "legendFormat": "p99 — {{protocol}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Bandit arm performance",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } }
      },
      "targets": [
        {
          "expr": "trading_learning_bandit_arm_pulls_total{bot_id=~\"$bot_id\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "pulls",
          "refId": "A"
        },
        {
          "expr": "trading_learning_bandit_arm_mean_reward{bot_id=~\"$bot_id\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "mean_reward",
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "variant_id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "__name__ 1": true, "__name__ 2": true },
            "renameByName": {
              "Value #A": "pulls",
              "Value #B": "mean_reward",
              "bot_id 1": "bot_id"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Slippage learner recommendations per (token_in, token_out)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "trading_learning_slippage_bps{bot_id=~\"$bot_id\"}",
          "legendFormat": "{{bot_id}} {{token_in}}→{{token_out}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Envelope renewal action rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (action) (rate(trading_envelope_renewal_actions_total{bot_id=~\"$bot_id\"}[15m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    }
  ]
}
