# Trading blueprint operator settings.
#
# Written by deploy/operator-install.sh — @TOKENS@ are substituted at install
# time. Edit the installed copy (chmod 600) and `systemctl restart
# trading-operator` to apply changes. Lines you add by hand are preserved on
# re-runs: the installer never overwrites an existing settings.env.

# ── Tangle protocol ───────────────────────────────────────────────────────────
BLUEPRINT_ID=@BLUEPRINT_ID@
# SERVICE_ID is assigned on-chain when a service instance is approved for this
# operator. The binary refuses to start without it (see OPERATORS.md).
SERVICE_ID=@SERVICE_ID@
CHAIN_ID=@CHAIN_ID@
TANGLE_CONTRACT=@TANGLE_CONTRACT@
STAKING_CONTRACT=@STAKING_CONTRACT@
RESTAKING_CONTRACT=@STAKING_CONTRACT@
STATUS_REGISTRY_CONTRACT=@STATUS_REGISTRY_CONTRACT@
STATUS_REGISTRY_ADDRESS=@STATUS_REGISTRY_CONTRACT@

# ── Chain RPC ─────────────────────────────────────────────────────────────────
HTTP_RPC_URL=@HTTP_RPC_URL@
RPC_URL=@HTTP_RPC_URL@
WS_RPC_URL=@WS_RPC_URL@

# ── Operator identity ─────────────────────────────────────────────────────────
# PRIVATE_KEY signs on-chain transactions and trade execution. It controls
# funds — this file must stay chmod 600 and never leave the box.
PRIVATE_KEY=@PRIVATE_KEY@
OPERATOR_ADDRESS=@OPERATOR_ADDRESS@
KEYSTORE_URI=@KEYSTORE_DIR@

# ── State + API surface ───────────────────────────────────────────────────────
BLUEPRINT_STATE_DIR=@BLUEPRINT_STATE_DIR@
OPERATOR_API_PORT=@OPERATOR_API_PORT@
TRADING_API_PORT=@TRADING_API_PORT@
# Public URL of the operator API. Advertised at registration so UIs (Arena)
# can discover and reach this operator.
OPERATOR_API_ENDPOINT=@OPERATOR_API_ENDPOINT@

# Browser origins allowed to read the public roster/trade endpoints. Keep in
# sync with the deployed Arena UI domains; add your own UI origin if you run one.
CORS_ALLOWED_ORIGINS=https://trading-arena.blueprint.tangle.tools,https://trading-arena.pages.dev

# ── Admission policy (fail closed) ────────────────────────────────────────────
# allowlist (default): only addresses in TRADING_REQUESTER_ALLOWLIST (plus the
# operator itself) may provision bots. Set to `public` ONLY when you are ready
# to accept bot requests from anyone — every active bot consumes your compute
# and, if you set an AI key below, your AI API budget.
TRADING_REQUESTER_ACCESS_MODE=allowlist
# Comma-separated 0x addresses permitted to request bots while in allowlist mode.
TRADING_REQUESTER_ALLOWLIST=

# Hard cap on concurrently served bots. Admission is rejected above this.
OPERATOR_MAX_CAPACITY=@OPERATOR_MAX_CAPACITY@

# Direct POST /api/bots bypasses on-chain service creation. Keep disabled
# outside local dev harnesses.
TRADING_ENABLE_DIRECT_BOT_CREATE=false

# ── Trading posture (paper by default) ────────────────────────────────────────
# New bots default to paper trading: real market data, simulated fills with
# honest fee/impact/gas modelling, zero on-chain trades. Flip per-bot via the
# operator API when you intentionally go live.
DEFAULT_PAPER_TRADE=true
DEFAULT_PAPER_INITIAL_CAPITAL_USD=10000
HYPERLIQUID_TESTNET=1

# ── Market data + validation ──────────────────────────────────────────────────
MARKET_DATA_BASE_URL=https://api.coingecko.com/api/v3
VALIDATION_DEADLINE_SECS=3600
VALIDATOR_MIN_SCORE=50
# Comma-separated trade-validator endpoints for live execution flows.
# VALIDATOR_ENDPOINTS=
# TRADING_ENVELOPE_TRUSTED_SIGNERS=

# ── Bot sandboxes ─────────────────────────────────────────────────────────────
# Public image on GHCR; the installer pre-pulls it. Pin a digest-suffixed tag
# (ghcr.io/tangle-network/blueprint-sidecar:all-harness-<sha>) for reproducible
# fleets.
SIDECAR_IMAGE=ghcr.io/tangle-network/blueprint-sidecar:all-harness

# ── AI provider (optional — YOU pay for every agentic run) ────────────────────
# Setting any of these enables agentic bot activation/chat. Costs accrue to
# YOUR key. There is currently NO built-in spend cap (see OPERATORS.md
# "Safety knobs" before setting these). Leave blank to serve deterministic
# strategy ticks only.
# ZAI_API_KEY=
# ANTHROPIC_API_KEY=
# TANGLE_API_KEY=
# OPENCODE_MODEL_PROVIDER=zai-coding-plan
# OPENCODE_MODEL_NAME=glm-4.7
# OPENCODE_MODEL_API_KEY=

# ── Pricing (informational; see OPERATORS.md "Economics") ────────────────────
# Advertised via GET /pricing/config. Signed service-creation quotes require
# the separate pricing-engine gRPC process (not installed by this script).
# SUBSCRIPTION_RATE=1000000000
# SUBSCRIPTION_INTERVAL=86400
# PRICING_ENGINE_ENDPOINT=
# Per-job x402 pricing (optional): place a job_pricing.toml under
# @DATA_DIR@/config/ — absent means x402 jobs are served free.
# JOB_PRICING_CONFIG_PATH=@DATA_DIR@/config/job_pricing.toml
# X402_CONFIG_PATH=@DATA_DIR@/config/x402.toml

# ── Session auth ──────────────────────────────────────────────────────────────
# Derived from the keystore/PRIVATE_KEY on first boot when left blank.
SESSION_AUTH_SECRET=@SESSION_AUTH_SECRET@

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,trading_blueprint_lib=debug,trading_runtime=debug
